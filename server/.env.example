# --- Server ---
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed browser origins (the web app).
CORS_ORIGIN=http://localhost:5173

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=NfLtwDKtZ4QavI7eBLSznH
JWT_EXPIRES_IN=7d

# --- Database ---
# Matches docker-compose.yml (host port 5433 -> container 5432).
DATABASE_URL=postgres://docs:docs@localhost:5433/docs

# Optional: a separate database used only by the automated tests.
# The test suite creates/drops its own schema, so point this at a
# throwaway database (defaults to appending _test if unset).
# TEST_DATABASE_URL=postgres://docs:docs@localhost:5433/docs_test

# Set to "true" when connecting to a managed Postgres that requires SSL
# (e.g. Render, Neon, Supabase). Leave unset/false for local Docker.
PGSSL=false
