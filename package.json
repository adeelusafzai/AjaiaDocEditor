{
  "name": "ajaia-docs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Ajaia Docs — a lightweight collaborative document editor (PERN stack)",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "setup:server": "npm --workspace server run db:setup",
    "dev": "concurrently -n api,web -c blue,magenta \"npm --workspace server run dev\" \"npm --workspace web run dev\"",
    "dev:api": "npm --workspace server run dev",
    "dev:web": "npm --workspace web run dev",
    "build": "npm --workspace web run build",
    "test": "npm --workspace server run test"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "overrides": {
    "htmlparser2": "8.0.2"
  },
  "engines": {
    "node": ">=20"
  }
}
